---
import Icon from './Icon.astro';
import { pair, getProfile } from '../lib/content';
const p = getProfile();
const name = pair(p.name);
const title = pair(p.title);
const affil = pair(p.affiliation);
const loc = pair(p.location);
---
<header class="hero">
  <img class="hero-photo" src={p.photo} alt={name.en} width="168" height="168" />
  <div class="hero-info">
    <h1><span data-l="en">{name.en}</span><span data-l="zh">{name.zh}</span></h1>
    <p class="title"><span data-l="en">{title.en}</span><span data-l="zh">{title.zh}</span></p>
    <p class="affil"><span data-l="en">{affil.en}</span><span data-l="zh">{affil.zh}</span></p>
    <p class="loc"><span data-l="en">{loc.en}</span><span data-l="zh">{loc.zh}</span></p>
    <div class="socials">
      {p.socials.filter((s) => s.url).map((s) => (
        <a href={s.url} title={s.label} target="_blank" rel="noopener noreferrer">
          <Icon name={s.key} /><span>{s.label}</span>
        </a>
      ))}
    </div>
  </div>
</header>
