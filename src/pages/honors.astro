---
import Base from '../layouts/Base.astro';
import L from '../components/L.astro';
import { pair, getHonors } from '../lib/content';
const honors = getHonors();
---
<Base title="Awards">
  <section>
    <ul class="award-list">
      {honors.map((h) => {
        const title = pair(h.title);
        const note = h.note ? pair(h.note) : null;
        return (
          <li class={h.highlight ? 'hl' : ''}>
            {h.url
              ? <a href={h.url} target="_blank" rel="noopener noreferrer"><strong><L en={title.en} zh={title.zh} /></strong></a>
              : <strong><L en={title.en} zh={title.zh} /></strong>}
            {note && <span class="award-note"> (<L en={note.en} zh={note.zh} />)</span>}
            {h.year && <span class="award-year"> — {h.year}</span>}
          </li>
        );
      })}
    </ul>
  </section>
</Base>
